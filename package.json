{
  "name": "devinx",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "private": true,
  "license": "MIT",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand --detectOpenHandles",
    "test:watch": "jest --watch",
    "bridge:build": "tsc -p bridge/tsconfig.json && node scripts/bridge/build-keychain-helper.mjs",
    "bridge:start": "npm run bridge:build && node dist/bridge/cli.js",
    "bridge:discover": "node scripts/bridge/discover-acp.mjs",
    "connector:build:macos": "node scripts/connector/build-macos.mjs",
    "connector:verify:macos": "node scripts/connector/verify-macos-artifact.mjs",
    "connector:notarize:macos": "node scripts/connector/notarize-macos.mjs",
    "connector:notarize:check": "node scripts/connector/notarize-macos.mjs --check",
    "connector:open:macos": "npm run connector:build:macos && open 'artifacts/connector/DevinX Connector.app'",
    "build": "echo 'EAS build is invoked via eas build; CI validates both app and bridge TypeScript' && tsc --noEmit && npm run bridge:build",
    "audit": "npm audit --audit-level=high",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build && npm run audit"
  },
  "dependencies": {
    "@expo/metro-runtime": "6.1.2",
    "@expo/vector-icons": "15.1.1",
    "@react-native-community/netinfo": "11.4.1",
    "@tanstack/react-query": "5.101.2",
    "ajv": "8.20.0",
    "expo": "54.0.35",
    "expo-asset": "12.0.13",
    "expo-audio": "1.1.1",
    "expo-build-properties": "1.0.10",
    "expo-constants": "18.0.13",
    "expo-dev-client": "6.0.21",
    "expo-document-picker": "14.0.8",
    "expo-font": "14.0.12",
    "expo-haptics": "15.0.8",
    "expo-image-picker": "17.0.11",
    "expo-linking": "8.0.12",
    "expo-router": "6.0.24",
    "expo-secure-store": "15.0.8",
    "expo-splash-screen": "31.0.13",
    "expo-sqlite": "16.0.10",
    "expo-status-bar": "3.0.9",
    "expo-updates": "29.0.18",
    "expo-video": "3.0.16",
    "expo-web-browser": "15.0.11",
    "nativewind": "4.2.6",
    "qrcode-terminal": "0.12.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "2.28.0",
    "react-native-markdown-display": "7.0.2",
    "react-native-reanimated": "4.1.7",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.16.0",
    "react-native-web": "0.21.2",
    "react-native-worklets": "0.5.1",
    "zod": "3.25.76",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native/eslint-config": "0.86.0",
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "26.1.1",
    "@types/react": "19.1.17",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "autoprefixer": "10.5.3",
    "babel-preset-expo": "54.0.11",
    "esbuild": "0.28.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "jest": "29.7.0",
    "jest-expo": "54.0.17",
    "postcss": "8.5.19",
    "prettier": "3.9.5",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": "24.18.0"
  },
  "overrides": {
    "@xmldom/xmldom": "0.8.13",
    "linkify-it": "5.0.2"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
