    {
      "id": "walkingRight",
      "label": "Walking Right",
      "description": "Internal locomotion row for moving Devin across an app surface.",
      "animation": {
        "kind": "atlas-row",
        "row": "running-right",
        "framesDir": "assets/frames/running-right",
        "rowIndex": 1,
        "frames": 8,
        "loop": true,
        "recommendedFps": 8
      }
    },
    {
      "id": "walkingLeft",
      "label": "Walking Left",
      "description": "Internal locomotion row for moving Devin across an app surface.",
      "animation": {
        "kind": "atlas-row",
        "row": "running-left",
        "framesDir": "assets/frames/running-left",
        "rowIndex": 2,
        "frames": 8,
        "loop": true,
        "recommendedFps": 8
      }
    }
  ]
}
