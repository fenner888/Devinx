{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "module": "Node16",
    "moduleResolution": "Node16",
    "noEmit": false,
    "noEmitOnError": true,
    "outDir": "../dist/bridge",
    "rootDir": "./src",
    "sourceMap": true,
    "target": "ES2022"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["../node_modules"]
}
