# DevinX environment variables — EXPO_PUBLIC_* only.
# These values are baked into the JS bundle at build time. NEVER put a real
# API key, org ID, or any secret here. The Devin API key is entered by the
# user at runtime and stored in the Keychain (spec §10.1).

# Sentry DSN (public, safe to ship in bundle). Leave blank to disable Sentry.
EXPO_PUBLIC_SENTRY_DSN=

# Personal Access Token feature flag (spec §8.2). PATs are in closed beta.
# Set to "true" to surface the PAT auth option in onboarding.
EXPO_PUBLIC_ENABLE_PAT=false


# Override the Devin API base URL (defaults to https://api.devin.ai).
# Only set for testing against a mock/staging host.
EXPO_PUBLIC_API_BASE_URL=https://api.devin.ai
